# 复制为 deploy/.env 后修改。密码建议只使用 URL 安全字符（字母、数字、._~-）。
POSTGRES_PASSWORD=replace-with-a-long-random-password

# 至少 32 字节随机值，例如：openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-random-bytes

# 首次启动且数据库中没有管理员时创建；已有管理员后不会重复执行。
ADMIN_NAME=Artifact Center Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Replace-With-A-Strong-Password-2026

# 浏览器访问地址；使用域名和 HTTPS 时填写最终外部地址。
APP_ORIGIN=http://localhost:8080

# Linux 主机对外监听端口。
APP_PORT=8080

# API 请求达到此耗时（毫秒）时记录为慢请求。
SLOW_REQUEST_MS=500
